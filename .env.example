# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Supabase (client-side) — anon key is safe to be public IF RLS is enabled on all tables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Firebase Push Notifications (optional)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# HelpBot / Claude API
# DANGER: VITE_ vars are visible in the browser bundle.
# Set this ONLY in local dev. For production, move the call to /api/helpbot.
VITE_ANTHROPIC_API_KEY=

# Vercel serverless (server-side only, no VITE_ prefix needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
